{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
, "src/app/our-services/page.jsx", "src/app/our-services/layout.jsx", "src/app/(dashboard)/admin/page.jsx", "src/app/(dashboard)/admin/layout.jsx", "src/app/(dashboard)/admin/settings/page.jsx", "src/app/(dashboard)/admin/attendance/page.jsx", "src/app/developments/page.jsx", "src/app/properties/page.jsx", "src/app/properties/layout.jsx", "src/app/page.jsx", "src/app/layout.jsx", "src/components/layout/Navbar.jsx", "src/components/PropertyCard.jsx", "src/components/properties/PropertyCard.jsx", "src/components/layout/Footer.jsx", "src/app/properties/[id]/page.jsx"  ],
  "exclude": ["node_modules"]
}
